{
  "manifest_version": 3,
  "name": "Focus Friction",
  "version": "1.0.0",
  "description": "Adds progressive friction to distracting websites to help you stay focused.",
  "key": "",

  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Focus Friction"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
